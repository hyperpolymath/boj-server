  name       = "sdp-shield"
  version    = "0.1.0"
  status     = Development
  tier       = Shield
  domain     = Secrets
  protocols  = [MCP]
  hash       = ""
  depends-on = []
  notes      = "Software Defined Perimeter. Auto-SDP for community nodes — invisible infrastructure, zero exposed ports until authenticated."
@end

@cartridge(id="dns-shield"):
  name       = "dns-shield"
  version    = "0.1.0"
  status     = Development
  tier       = Shield
  domain     = Observe
  protocols  = [MCP]
  hash       = ""
